# Addon display name shown in Stremio and on the configuration page
ADDON_NAME=IPTV Stremio Addon
# Short description shown in Stremio
ADDON_DESCRIPTION=Stream your IPTV channels in Stremio
# Optional: URL of a logo/icon image to display in Stremio (leave commented out to disable)
# ADDON_LOGO_URL=https://example.com/logo.png

# Enable/disable logo proxy resizing to enforce Stremio 2:3 aspect ratio
LOGO_RESIZE_ENABLED=true

# Enable/disable Cache-Control headers on proxied logos
LOGO_CACHE_ENABLED=true

# Port to run the HTTP server on
PORT=7000

# Enable/disable in-memory caching (true/false)
CACHE_ENABLED=true

# TTL (ms) for interface cache (default 6 hours)
CACHE_TTL_MS=21600000

# Max in-memory interface cache entries
MAX_CACHE_ENTRIES=100

# Enable/disable the server-side prefetch proxy (bypasses browser CORS for playlist/EPG validation)
PREFETCH_ENABLED=true

# Max bytes the prefetch proxy will download per request (default ~150 MB)
PREFETCH_MAX_BYTES=150000000

# Optional secret to enable encrypted configuration tokens (must be >=16 chars)
# To generate a random string, you can run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CONFIG_SECRET=change_this_to_a_long_random_secret_string

# Enable verbose debug logging (true/false)
DEBUG_MODE=false