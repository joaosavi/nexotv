# Addon display name shown in Stremio and on the configuration page
ADDON_NAME=IPTV Stremio Addon
# Short description shown in Stremio
ADDON_DESCRIPTION=Stream your IPTV channels in Stremio
# Optional: URL of a logo/icon image to display in Stremio (leave commented out to disable)
# ADDON_LOGO_URL=https://example.com/logo.png

# Enable/disable Cache-Control headers on proxied logos
LOGO_CACHE_ENABLED=true

# Port to run the HTTP server on
PORT=7000

# Enable/disable persistent SQLite caching (true/false)
CACHE_ENABLED=true

# TTL (ms) for cache entries (default 6 hours)
CACHE_TTL_MS=21600000

# TTL (ms) for IPTV-org cache entries (default 6 hours)
IPTV_ORG_CACHE_TTL_MS=21600000

# Max in-memory cache entries (build promises and interface caches)
MAX_CACHE_ENTRIES=100

# Path to the SQLite cache database file (default: ./data/cache.sqlite)
# In Docker, set to /app/data/cache.sqlite and mount a volume
# SQLITE_PATH=./data/cache.sqlite

# How often (ms) to delete expired cache entries from the database (default: 6 hours)
# Lower values = entries removed faster; higher values = less DB overhead
# SQLITE_GC_INTERVAL_MS=21600000

# How often (ms) to run VACUUM and reclaim free disk space (default: 7 days)
# VACUUM rewrites the whole DB file — run it infrequently. Only matters after heavy eviction.
# SQLITE_VACUUM_INTERVAL_MS=604800000

# Enable/disable the server-side prefetch proxy (bypasses browser CORS for playlist/EPG validation)
PREFETCH_ENABLED=true

# Max bytes the prefetch proxy will download per request (default ~150 MB)
PREFETCH_MAX_BYTES=150000000

# Optional secret to enable encrypted configuration tokens (must be >=16 chars)
# To generate a random string, you can run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CONFIG_SECRET=change_this_to_a_long_random_secret_string

# Enable verbose debug logging (true/false)
DEBUG_MODE=false

# RATE LIMITING
# Enable global IP-based rate limiting
IP_RATE_LIMIT_ENABLED=true
# Window in ms for IP rate limit (default 300000 ms = 5 minutes)
IP_RATE_LIMIT_WINDOW_MS=300000
# Max requests per window for IP rate limit
IP_RATE_LIMIT_MAX=300

# Enable token-based rate limiting for addon routes
TOKEN_RATE_LIMIT_ENABLED=true
# Window in ms for token rate limit (default 60000 ms = 1 minute)
TOKEN_RATE_LIMIT_WINDOW_MS=60000
# Max requests per window for token rate limit
TOKEN_RATE_LIMIT_MAX=60