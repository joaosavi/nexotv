# ==============================================================================
#                         ESSENTIAL ADDON SETUP
# ==============================================================================
# Customize your addon identity. These are shown in Stremio and the config page.

# --- Addon Identity ---
# Descriptive name for your addon instance.
ADDON_NAME=NexoTV
# Short description shown in Stremio.
ADDON_DESCRIPTION=Stream your IPTV channels in Stremio
# Logo/icon image to display in Stremio and on the configure page.
# To use a local image, place it in public/logo/ and point here:
#   ADDON_LOGO_URL=http://localhost:7000/logo/addon-logo.png
# Or use any external URL:
#   ADDON_LOGO_URL=https://example.com/logo.png
# Default: built-in fallback image
# ADDON_LOGO_URL=

# --- Network ---
# Port to run the HTTP server on.
# Default: 7000
# PORT=7000


# ==============================================================================
#                              SECURITY
# ==============================================================================

# Optional secret to enable AES-256-GCM encryption for configuration tokens.
# Strongly recommended for public deployments. Must be >= 16 characters.
# Generate a random value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CONFIG_SECRET=change_this_to_a_long_random_secret_string


# ==============================================================================
#                           CACHE CONFIGURATION
# ==============================================================================
# All cache variables have sensible defaults. Uncomment only what you want to change.

# --- SQLite Persistent Cache ---
# Enable/disable persistent SQLite caching.
# Default: true
# CACHE_ENABLED=true

# Path to the SQLite cache file. In Docker, set to /app/data/cache.sqlite and mount a volume.
# Default: ./data/cache.sqlite
# SQLITE_PATH=./data/cache.sqlite

# How often (ms) to delete expired entries from the database.
# Default: 21600000 (6 hours)
# SQLITE_GC_INTERVAL_MS=21600000

# How often (ms) to run VACUUM and reclaim free disk space.
# VACUUM rewrites the whole DB file — run it infrequently.
# Default: 604800000 (7 days)
# SQLITE_VACUUM_INTERVAL_MS=604800000

# --- Cache TTLs ---
# How long (ms) Xtream Codes data is cached.
# Default: 21600000 (6 hours)
# CACHE_TTL_MS=21600000

# How long (ms) IPTV-org data is cached.
# Default: 21600000 (6 hours)
# IPTV_ORG_CACHE_TTL_MS=21600000

# How long (ms) M3U/M3U+ playlist data is cached.
# Default: 21600000 (6 hours)
# M3U_CACHE_TTL_MS=21600000

# --- In-Memory Eviction ---
# How long (ms) channel/EPG data stays in RAM after the last request before being evicted.
# Data is reloaded from SQLite on demand. Lower = less RAM, more SQLite reads.
# Default: 300000 (5 minutes)
# DATA_MEMORY_TTL_MS=300000

# Max in-memory addon instances (lightweight — channel data lives in SQLite, not RAM).
# Default: 300
# MAX_CACHE_ENTRIES=300

# --- Logo Cache ---
# Enable/disable Cache-Control headers on proxied logos.
# Default: true
# LOGO_CACHE_ENABLED=true


# ==============================================================================
#                             PREFETCH PROXY
# ==============================================================================
# Server-side prefetch proxy that bypasses browser CORS for playlist/EPG validation.

# Enable/disable the prefetch proxy.
# Default: true
# PREFETCH_ENABLED=true

# Max bytes the prefetch proxy will download per request.
# Default: 150000000 (~150 MB)
# PREFETCH_MAX_BYTES=150000000


# ==============================================================================
#                           RATE LIMITING
# ==============================================================================
# Protects the server from abuse. Defaults are suitable for most deployments.

# --- Global IP Rate Limit ---
# Default: true
# IP_RATE_LIMIT_ENABLED=true
# Window in ms.  Default: 300000 (5 minutes)
# IP_RATE_LIMIT_WINDOW_MS=300000
# Max requests per window.  Default: 300
# IP_RATE_LIMIT_MAX=300

# --- Per-Token Rate Limit (addon routes) ---
# Default: true
# TOKEN_RATE_LIMIT_ENABLED=true
# Window in ms.  Default: 60000 (1 minute)
# TOKEN_RATE_LIMIT_WINDOW_MS=60000
# Max requests per window.  Default: 60
# TOKEN_RATE_LIMIT_MAX=60


# ==============================================================================
#                           ADVANCED / DEBUGGING
# ==============================================================================

# Allow localhost/private IPs as stream/playlist sources (useful for local testing).
# Default: false
# ALLOW_LOCAL_URLS=false

# Enable verbose debug logging.
# Default: false
# DEBUG_MODE=false
